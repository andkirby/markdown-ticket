{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "entry": ["src/**/*.tsx", "src/**/*.ts", "**/*.test.ts", "**/*.test.tsx", "**/*.spec.ts", "**/*.spec.tsx", "src/test-setup.ts", "tailwind.config.js", "postcss.config.js"],
      "project": ["src/**/*.ts", "src/**/*.tsx"]
    },
    "server": {
      "entry": ["server.ts", "fileWatcherService.ts", "eslint.config.ts"],
      "project": ["**/*.ts", "*.ts"]
    }
  },
  "ignore": [
    "shared/**",
    "domain-contracts/**",
    "mcp-server/**",
    ".claude/**",
    "**/node_modules/**",
    "**/dist/**",
    "**/coverage/**",
    "**/.next/**",
    "**/build/**",
    "**/mocks/**",
    "**/__mocks__/**",
    "**/mcp-dev-tools/**",
    "scripts/**",
    ".gitWT/**",
    "docs/**"
  ],
  "ignoreBinaries": ["jq", "prettier", "rimraf", "rg"],
  "ignoreDependencies": ["happy-dom", "swagger-jsdoc", "@typescript-eslint/eslint-plugin", "@typescript-eslint/parser"]
}
