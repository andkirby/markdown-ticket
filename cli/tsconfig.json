{
  "compilerOptions": {
    "target": "ES2022",
    "rootDir": "src",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "paths": {
      "@mdt/shared": ["../shared/dist/index.js"],
      "@mdt/shared/*": ["../shared/dist/*"]
    },
    "strict": true,
    "noImplicitAny": false,
    "declaration": true,
    "outDir": "./dist",
    "sourceMap": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "tests"]
}
