#!/bin/sh
# Pre-commit hook: Security + quality checks
#
# Checks:
#   1. Block .env files (secrets)
#   2. Block docs/CRs/*/*.trace.md files
#   3. Block ../shared/ imports (enforce @mdt/shared alias)
#   4. Block absolute home paths in code
#   5. Run knip on .ts files
#   6. Check markdown code fences (broken/unclosed blocks)

set -e

# Source check functions
HOOK_DIR="$(dirname "$0")"
. "$HOOK_DIR/lib/block-env-files.sh"
. "$HOOK_DIR/lib/block-trace-files.sh"
. "$HOOK_DIR/lib/block-shared-imports.sh"
. "$HOOK_DIR/lib/block-home-paths-code.sh"
. "$HOOK_DIR/lib/run-knip.sh"
. "$HOOK_DIR/lib/check-markdown-fences.sh"

# Run checks
block_env_files
block_trace_files
block_shared_imports
block_home_paths_code
run_knip
check_markdown_fences

exit 0
