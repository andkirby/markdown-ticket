{
  "version": 1,
  "ticket": {
    "key": "MDT-096"
  },
  "requirements": [
    {
      "id": "BR-1.1",
      "kind": "behavior",
      "text": "FileWatcherService monitors multiple directory paths simultaneously",
      "sourceRef": "CR:MDT-096",
      "routePolicy": "bdd"
    },
    {
      "id": "BR-1.2",
      "kind": "behavior",
      "text": "SSE events identify which project path triggered the change",
      "sourceRef": "CR:MDT-096",
      "routePolicy": "bdd"
    },
    {
      "id": "BR-1.3",
      "kind": "behavior",
      "text": "Service accepts dynamic path additions at runtime",
      "sourceRef": "CR:MDT-096",
      "routePolicy": "bdd"
    },
    {
      "id": "BR-1.4",
      "kind": "behavior",
      "text": "Service accepts dynamic path removals at runtime",
      "sourceRef": "CR:MDT-096",
      "routePolicy": "bdd"
    },
    {
      "id": "BR-1.5",
      "kind": "behavior",
      "text": "Existing single-path API remains functional for backward compatibility",
      "sourceRef": "CR:MDT-096",
      "routePolicy": "bdd"
    },
    {
      "id": "C-2.1",
      "kind": "constraint",
      "text": "Must not degrade file watching performance (<5% overhead per additional path)",
      "sourceRef": "CR:MDT-096",
      "routePolicy": "not_applicable"
    },
    {
      "id": "C-2.2",
      "kind": "constraint",
      "text": "Must maintain existing SSE event format for backward compatibility",
      "sourceRef": "CR:MDT-096",
      "routePolicy": "not_applicable"
    },
    {
      "id": "C-2.3",
      "kind": "constraint",
      "text": "Each service module must not exceed 150 lines",
      "sourceRef": "CR:MDT-096",
      "routePolicy": "not_applicable"
    },
    {
      "id": "C-2.4",
      "kind": "constraint",
      "text": "Must gracefully degrade if watcher creation fails (log error, continue)",
      "sourceRef": "CR:MDT-096",
      "routePolicy": "not_applicable"
    },
    {
      "id": "Edge-3.1",
      "kind": "edge_case",
      "text": "Handle concurrent add/remove operations without race conditions",
      "sourceRef": "CR:MDT-096",
      "routePolicy": "not_applicable"
    },
    {
      "id": "Edge-3.2",
      "kind": "edge_case",
      "text": "Handle watcher creation failure for individual paths without affecting other watchers",
      "sourceRef": "CR:MDT-096",
      "routePolicy": "not_applicable"
    },
    {
      "id": "BR-1.6",
      "kind": "behavior",
      "text": "Global registry watcher detects project config changes and broadcasts events",
      "sourceRef": "CR:MDT-096",
      "routePolicy": "bdd"
    },
    {
      "id": "BR-1.7",
      "kind": "behavior",
      "text": "Cache invalidation triggers when watched files change",
      "sourceRef": "CR:MDT-096",
      "routePolicy": "bdd"
    },
    {
      "id": "C-2.5",
      "kind": "constraint",
      "text": "Debouncing prevents rapid duplicate events within 100ms window",
      "sourceRef": "CR:MDT-096",
      "routePolicy": "not_applicable"
    },
    {
      "id": "C-2.6",
      "kind": "constraint",
      "text": "Heartbeat runs every 30 seconds to detect dead connections",
      "sourceRef": "CR:MDT-096",
      "routePolicy": "not_applicable"
    }
  ],
  "scenarios": [
    {
      "id": "multi_path_monitoring",
      "title": "Multiple paths monitored simultaneously",
      "covers": [
        "BR-1.1"
      ],
      "given": "FileWatcherService is initialized",
      "when": "with multiple project paths registered",
      "then": "each path has an active watcher and changes trigger events",
      "sourceRef": "CR:MDT-096"
    },
    {
      "id": "sse_path_identification",
      "title": "SSE events identify source path",
      "covers": [
        "BR-1.2"
      ],
      "given": "A file change occurs in a watched path",
      "when": "when the SSE event is broadcast",
      "then": "the event data includes the projectId that triggered it",
      "sourceRef": "CR:MDT-096"
    },
    {
      "id": "dynamic_path_addition",
      "title": "Paths can be added at runtime",
      "covers": [
        "BR-1.3"
      ],
      "given": "FileWatcherService is running",
      "when": "when addWatcher() is called with a new path",
      "then": "the new watcher is created and begins monitoring",
      "sourceRef": "CR:MDT-096"
    },
    {
      "id": "dynamic_path_removal",
      "title": "Paths can be removed at runtime",
      "covers": [
        "BR-1.4"
      ],
      "given": "Multiple watchers are active",
      "when": "when removeWorktreeWatcher() is called",
      "then": "the specified watcher is closed and removed without affecting others",
      "sourceRef": "CR:MDT-096"
    },
    {
      "id": "backward_compat_single_path",
      "title": "Single-path API still works",
      "covers": [
        "BR-1.5"
      ],
      "given": "Existing code uses initFileWatcher()",
      "when": "with a single path argument",
      "then": "file watching works as before",
      "sourceRef": "CR:MDT-096"
    },
    {
      "id": "registry_changes_detected",
      "title": "Registry config changes trigger events",
      "covers": [
        "BR-1.6"
      ],
      "given": "Global registry watcher is active",
      "when": "a project .toml file is added/changed/removed",
      "then": "a project-created/updated/deleted event is broadcast to SSE clients",
      "sourceRef": "CR:MDT-096"
    },
    {
      "id": "cache_invalidated_on_change",
      "title": "File changes invalidate cache",
      "covers": [
        "BR-1.7"
      ],
      "given": "FileInvoker is connected to watcher",
      "when": "a watched file changes",
      "then": "invalidateFile() is called with the file path",
      "sourceRef": "CR:MDT-096"
    }
  ],
