{
  "version": 1,
  "ticket": {
    "key": "MDT-171"
  },
  "requirements": [
    {
      "id": "BR-1.1",
      "kind": "behavior",
      "text": "WHEN the user marks an eligible folder as a fav, the system shall persist that folder as a project-scoped fav and show its active star state.",
      "sourceRef": "CR 4 Functional; research/document-favs-proposal.md UI Behavior",
      "routePolicy": "bdd",
      "tags": [
        "timing:in-ticket"
      ]
    },
    {
      "id": "BR-1.2",
      "kind": "behavior",
      "text": "WHEN the user marks an eligible markdown document as a fav, the system shall persist that document as a project-scoped fav and show its active star state.",
      "sourceRef": "CR 4 Functional; research/document-favs-proposal.md UI Behavior",
      "routePolicy": "bdd",
      "tags": [
        "timing:in-ticket"
      ]
    },
    {
      "id": "BR-1.3",
      "kind": "behavior",
      "text": "WHEN at least one reconciled fav exists, the system shall display a compact Favs section above Recent.",
      "sourceRef": "CR 4 Functional; research/document-favs-proposal.md Recommendation",
      "routePolicy": "bdd",
      "tags": [
        "timing:in-ticket"
      ]
    },
    {
      "id": "BR-1.4",
      "kind": "behavior",
      "text": "WHEN no reconciled favs exist, the system shall hide the Favs section.",
      "sourceRef": "CR 4 Functional; research/document-favs-proposal.md UI Behavior",
      "routePolicy": "bdd",
      "tags": [
        "timing:in-ticket"
      ]
    },
    {
      "id": "BR-1.5",
      "kind": "behavior",
      "text": "WHILE an item is currently a fav, the system shall show active star state for that item in tree rows and fav rows.",
      "sourceRef": "CR 4 Functional; research/document-favs-proposal.md Icon Decision",
      "routePolicy": "bdd",
      "tags": [
        "timing:in-ticket"
      ]
    },
    {
      "id": "BR-1.6",
      "kind": "behavior",
      "text": "WHEN the user selects the active star for a fav, the system shall remove that fav from persisted state and from the Favs section.",
      "sourceRef": "CR 4 Functional; research/document-favs-proposal.md UI Behavior",
      "routePolicy": "bdd",
      "tags": [
        "timing:in-ticket"
      ]
    },
    {
      "id": "BR-2.1",
      "kind": "behavior",
      "text": "WHEN the user selects a document fav, the system shall open that markdown document and select the matching tree row.",
      "sourceRef": "CR 4 Functional; research/document-favs-proposal.md UI Behavior",
      "routePolicy": "bdd",
      "tags": [
        "timing:in-ticket"
      ]
    },
    {
      "id": "BR-2.2",
      "kind": "behavior",
      "text": "WHEN the user selects a folder fav, the system shall expand the folder ancestors and scroll or locate the folder row in the tree.",
      "sourceRef": "CR 4 Functional; research/document-favs-proposal.md UI Behavior",
      "routePolicy": "bdd",
      "tags": [
        "timing:in-ticket"
      ]
    },
    {
      "id": "BR-2.3",
      "kind": "behavior",
      "text": "WHEN the Documents View reloads for the same project, the system shall restore reconciled favs from durable project-scoped state.",
      "sourceRef": "CR 5 Verification; assessment Persistence owner",
      "routePolicy": "bdd",
      "tags": [
        "timing:in-ticket"
      ]
    },
    {
      "id": "BR-3.1",
      "kind": "behavior",
      "text": "WHEN the document tree is loaded, the system shall expose favorite state and favorited timestamp metadata for eligible fav nodes without changing non-favorite tree behavior.",
      "sourceRef": "research/document-favs-proposal.md Endpoint Reuse; assessment Documents API route boundary",
      "routePolicy": "bdd",
      "tags": [
        "timing:in-ticket"
      ]
    },
    {
      "id": "BR-3.2",
      "kind": "behavior",
      "text": "WHEN fav state is written for a resolved project, the system shall save the complete ordered fav list for that project.",
      "sourceRef": "research/document-favs-proposal.md Data Location and Endpoint Reuse",
      "routePolicy": "bdd",
      "tags": [
        "timing:in-ticket"
      ]
    },
    {
      "id": "BR-3.3",
      "kind": "behavior",
      "text": "WHEN the user opens existing Recent or All Documents navigation, the system shall preserve existing Recent and document tree selection behavior.",
      "sourceRef": "CR 2 Constraints; assessment Test safety",
      "routePolicy": "bdd",
      "tags": [
        "timing:in-ticket"
      ]
    },
    {
      "id": "C1",
      "kind": "constraint",
      "text": "The system shall store document fav state under CONFIG_DIR/projects/{project.id}/document-favs.json.",
      "sourceRef": "User decision; assessment CONFIG_DIR project-state path",
      "routePolicy": "tests",
      "tags": [
        "timing:in-ticket"
      ]
    },
    {
      "id": "C2",
      "kind": "constraint",
      "text": "The system shall not store document fav state in .mdt-config.toml.",
      "sourceRef": "CR 2 Constraints; docs/architecture/preference-storage-architecture.md",
      "routePolicy": "tests",
      "tags": [
        "timing:in-ticket"
      ]
    },
    {
      "id": "C3",
      "kind": "constraint",
      "text": "The system shall keep document favs project-scoped by resolving API lookup input to the canonical project.id before selecting the state file.",
      "sourceRef": "research/document-favs-proposal.md Data Location",
      "routePolicy": "tests",
      "tags": [
        "timing:in-ticket"
      ]
    },
    {
      "id": "C4",
      "kind": "constraint",
      "text": "The system shall persist fav records with project-relative path, type of file or folder, and favoritedAt timestamp.",
      "sourceRef": "research/document-favs-proposal.md Data Location",
      "routePolicy": "tests",
      "tags": [
        "timing:in-ticket"
      ]
    },
    {
      "id": "C5",
      "kind": "constraint",
      "text": "The system shall accept only folders and markdown documents that are present in the eligible document tree as fav targets.",
      "sourceRef": "CR 2 Scope; research/document-favs-proposal.md Validation rules",
      "routePolicy": "tests",
      "tags": [
        "timing:in-ticket"
      ]
    },
    {
      "id": "C7",
      "kind": "constraint",
      "text": "The system shall validate fav path input as project-relative, normalized, non-empty, non-absolute, and free of parent-directory traversal before persistence.",
      "sourceRef": "research/document-favs-proposal.md Validation rules",
      "routePolicy": "tests",
      "tags": [
        "timing:in-ticket"
      ]
    },
    {
      "id": "C8",
      "kind": "constraint",
      "text": "The system shall keep Favs and Recent outside the document tree scroll area and keep tree rows compact without increasing sidebar row height.",
      "sourceRef": "CR 4 Non-Functional; docs/design/surfaces/documents-view-navigation.spec.md Layout",
      "routePolicy": "tests",
      "tags": [
        "timing:in-ticket"
      ]
    },
    {
      "id": "C9",
      "kind": "constraint",
      "text": "The system shall use only `PUT /api/documents/favs` for document fav writes and shall not write fav state through `.mdt-config.toml`, `/api/documents/configure`, `/api/documents/content`, project config routes, or `/api/config/selector`.",
      "sourceRef": "research/document-favs-proposal.md Endpoint Reuse",
      "routePolicy": "tests",
      "tags": [
        "timing:in-ticket"
      ]
    },
    {
      "id": "Edge-1",
      "kind": "edge_case",
      "text": "IF a stored fav path no longer exists in the eligible document tree, THEN the system shall remove or ignore that fav on refresh.",
      "sourceRef": "CR 4 Edge Cases; research/document-favs-proposal.md UI Behavior",
      "routePolicy": "tests",
      "tags": [
        "timing:in-ticket"
      ]
    },
    {
      "id": "Edge-2",
      "kind": "edge_case",
      "text": "IF a stored fav path is outside configured document roots, THEN the system shall not expose it as a usable fav.",
      "sourceRef": "CR 4 Edge Cases; research/document-favs-proposal.md Validation rules",
      "routePolicy": "tests",
      "tags": [
        "timing:in-ticket"
      ]
    },
    {
      "id": "Edge-3",
      "kind": "edge_case",
      "text": "IF a stored fav path is under docs/CRs or the configured ticket path, THEN the system shall not expose it as a usable document fav.",
      "sourceRef": "CR 4 Edge Cases; docs/design/surfaces/documents-view-navigation.spec.md Navigation Rules",
      "routePolicy": "tests",
      "tags": [
        "timing:in-ticket"
      ]
    },
    {
      "id": "Edge-4",
      "kind": "edge_case",
      "text": "IF stored fav state is missing, malformed, or invalid JSON, THEN the system shall fall back to an empty fav list without breaking Documents View.",
      "sourceRef": "CR 4 Edge Cases; research/document-favs-proposal.md Tests",
      "routePolicy": "tests",
      "tags": [
        "timing:in-ticket"
      ]
    },
    {
      "id": "Edge-5",
      "kind": "edge_case",
      "text": "IF a fav write references an unknown project, THEN the system shall reject the write without creating document fav state for an unresolved project.",
      "sourceRef": "research/document-favs-proposal.md Validation rules",
      "routePolicy": "tests",
      "tags": [
        "timing:in-ticket"
      ]
    },
    {
      "id": "C6",
      "kind": "constraint",
      "text": "The system shall use the existing project favorite star active/inactive states, hover/focus affordance, and accessible label pattern for document fav controls, unless architecture documents a specific incompatibility.",
      "sourceRef": "Reviewer GAP-2; research/document-favs-proposal.md Visual Pattern",
      "routePolicy": "tests",
      "tags": [
        "timing:in-ticket"
      ]
    },
    {
      "id": "C10",
      "kind": "constraint",
      "text": "The system shall show at most five fav rows in the initial Favs section unless architecture defines an explicit overflow affordance.",
      "sourceRef": "Reviewer GAP-1; research/document-favs-proposal.md Sidebar Clarity",
      "routePolicy": "tests",
      "tags": [
        "timing:in-ticket"
      ]
    }
  ],
  "scenarios": [
    {
      "id": "folder_fav_appears_active",
      "title": "Folder fav appears with active stars",
      "covers": [
        "BR-1.1",
        "BR-1.3",
        "BR-1.5"
      ],
      "given": "Given I am viewing Documents with an eligible folder that is not yet a fav",
      "when": "When I select the folder row star",
      "then": "Then the folder appears in a compact Favs section above Recent and both the folder row and fav row show active star state",
      "sourceRef": "docs/CRs/MDT-171/requirements.trace.md#br-1"
    },
    {
      "id": "markdown_fav_appears_active",
      "title": "Markdown document fav appears with active stars",
      "covers": [
        "BR-1.2",
        "BR-1.3",
        "BR-1.5"
      ],
      "given": "Given I am viewing Documents with an eligible markdown document that is not yet a fav",
      "when": "When I select the document row star",
      "then": "Then the document appears in a compact Favs section above Recent and both the document row and fav row show active star state",
      "sourceRef": "docs/CRs/MDT-171/requirements.trace.md#br-1"
    },
    {
      "id": "empty_favs_section_is_hidden",
      "title": "Empty Favs section is hidden",
      "covers": [
        "BR-1.4"
      ],
      "given": "Given I am viewing Documents for a project with no reconciled favs",
      "when": "When the document tree finishes loading",
      "then": "Then the Favs section is not shown and Recent and All Documents remain visible",
      "sourceRef": "docs/CRs/MDT-171/requirements.trace.md#br-1"
    },
    {
      "id": "active_star_removes_fav",
      "title": "Active star removes a fav",
      "covers": [
        "BR-1.6",
        "BR-1.4"
      ],
      "given": "Given I am viewing Documents with a single document fav visible in Favs",
      "when": "When I select the active star for that fav",
      "then": "Then the fav is removed from persisted favs and the Favs section is hidden",
      "sourceRef": "docs/CRs/MDT-171/requirements.trace.md#br-1"
    },
    {
      "id": "document_fav_opens_document",
      "title": "Document fav opens the markdown document",
      "covers": [
        "BR-2.1"
      ],
      "given": "Given I am viewing Documents with a markdown document fav visible in Favs",
      "when": "When I select the document fav row",
      "then": "Then that markdown document opens and the matching document tree row is selected",
      "sourceRef": "docs/CRs/MDT-171/requirements.trace.md#br-2"
    },
    {
      "id": "folder_fav_locates_folder",
      "title": "Folder fav expands and locates the folder",
      "covers": [
        "BR-2.2"
      ],
      "given": "Given I am viewing Documents with a nested folder fav visible in Favs and its ancestors collapsed",
      "when": "When I select the folder fav row",
      "then": "Then the folder ancestors expand and the matching folder row is located in the tree",
      "sourceRef": "docs/CRs/MDT-171/requirements.trace.md#br-2"
    },
    {
      "id": "reload_restores_reconciled_favs",
      "title": "Reload restores reconciled favs for the project",
      "covers": [
        "BR-2.3",
        "BR-3.1"
      ],
      "given": "Given I have saved folder and markdown document favs for the current project",
      "when": "When I reload Documents View for the same project",
      "then": "Then reconciled favs are restored and eligible tree nodes expose favorite state and favorited timestamps without changing non-favorite rows",
      "sourceRef": "docs/CRs/MDT-171/requirements.trace.md#br-2"
    },
    {
      "id": "ordered_write_preserves_existing_navigation",
      "title": "Ordered fav write preserves existing navigation behavior",
      "covers": [
        "BR-3.2",
        "BR-3.3"
      ],
      "given": "Given Documents View has existing Recent entries and All Documents selection behavior",
      "when": "When the fav list is saved in a new order for the resolved project",
      "then": "Then the complete ordered fav list is saved for that project and existing Recent and All Documents navigation behavior is unchanged",
      "sourceRef": "docs/CRs/MDT-171/requirements.trace.md#br-3"
    }
  ],
