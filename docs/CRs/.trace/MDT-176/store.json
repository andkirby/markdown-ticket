{
  "version": 1,
  "ticket": {
    "key": "MDT-176"
  },
  "requirements": [
    {
      "id": "BR-1.1",
      "kind": "behavior",
      "text": "WHEN project loading returns 401 Authentication required, the system shall show a locked-board state instead of any empty-project state.",
      "sourceRef": "docs/CRs/MDT-176-browser-auth-session-unlock.md#problem; docs/design/surfaces/auth-session-unlock.spec.md#critical-ux-rules",
      "routePolicy": "bdd",
      "tags": [
        "timing:in-ticket"
      ]
    },
    {
      "id": "BR-1.2",
      "kind": "behavior",
      "text": "WHILE the board is locked, the system shall provide a password-style access-token input and unlock action.",
      "sourceRef": "docs/CRs/MDT-176-browser-auth-session-unlock.md#functional; docs/design/surfaces/auth-session-unlock.spec.md#state-model",
      "routePolicy": "bdd",
      "tags": [
        "timing:in-ticket"
      ]
    },
    {
      "id": "BR-1.3",
      "kind": "behavior",
      "text": "WHEN a valid owner access token is submitted, the system shall establish an owner browser session and load manageable projects without requiring the token to be entered again.",
      "sourceRef": "docs/CRs/MDT-176-browser-auth-session-unlock.md#desired-outcome; docs/design/surfaces/auth-session-unlock.spec.md#unlock-flow",
      "routePolicy": "bdd",
      "tags": [
        "timing:in-ticket"
      ]
    },
    {
      "id": "BR-1.4",
      "kind": "behavior",
      "text": "IF the submitted access token is invalid, THEN the system shall keep the locked panel visible and show a generic inline rejection message.",
      "sourceRef": "docs/CRs/MDT-176-browser-auth-session-unlock.md#functional; docs/design/surfaces/auth-session-unlock.spec.md#copy",
      "routePolicy": "bdd",
      "tags": [
        "timing:in-ticket"
      ]
    },
    {
      "id": "BR-1.5",
      "kind": "behavior",
      "text": "WHILE no owner session is established, the system shall keep project-management actions unavailable to the browser user.",
      "sourceRef": "docs/CRs/MDT-176-browser-auth-session-unlock.md#functional; docs/design/surfaces/auth-session-unlock.spec.md#critical-ux-rules",
      "routePolicy": "bdd",
      "tags": [
        "timing:in-ticket"
      ]
    },
    {
      "id": "BR-1.6",
      "kind": "behavior",
      "text": "WHEN the user locks or logs out of an owner session, the system shall clear the browser session and return to the locked state without mutating project data.",
      "sourceRef": "docs/CRs/MDT-176-browser-auth-session-unlock.md#functional; docs/design/surfaces/auth-session-unlock.spec.md#critical-ux-rules",
      "routePolicy": "bdd",
      "tags": [
        "timing:in-ticket"
      ]
    },
    {
      "id": "BR-1.7",
      "kind": "behavior",
      "text": "WHILE backend authentication is disabled for local development or test mode, the system shall load the normal application without an unlock prompt.",
      "sourceRef": "docs/CRs/MDT-176-browser-auth-session-unlock.md#scope; docs/CRs/MDT-176/assess.md#current-system-assumptions",
      "routePolicy": "bdd",
      "tags": [
        "timing:in-ticket"
      ]
    },
    {
      "id": "BR-1.8",
      "kind": "behavior",
      "text": "WHEN anonymous project loading returns public read-only projects after MDT-172, the system shall render those projects with owner actions unavailable and an unlock affordance available.",
      "sourceRef": "docs/CRs/MDT-176-browser-auth-session-unlock.md#mdt-172-compatibility; docs/design/surfaces/auth-session-unlock.spec.md#mdt-172-compatibility",
      "routePolicy": "bdd",
      "tags": [
        "timing:in-ticket"
      ]
    },
    {
      "id": "BR-1.9",
      "kind": "behavior",
      "text": "WHEN anonymous project loading returns 200 with an empty public list after MDT-172, the system shall show a no-public-projects state with an unlock affordance and no project-creation action.",
      "sourceRef": "docs/CRs/MDT-176-browser-auth-session-unlock.md#mdt-172-compatibility; docs/design/surfaces/auth-session-unlock.spec.md#mdt-172-compatibility",
      "routePolicy": "bdd",
      "tags": [
        "timing:in-ticket"
      ]
    },
    {
      "id": "BR-1.10",
      "kind": "behavior",
      "text": "IF an unlock attempt fails, THEN the system shall preserve the unlock context and keep focus available for token correction.",
      "sourceRef": "docs/design/surfaces/auth-session-unlock.spec.md#accessibility; docs/design/surfaces/auth-session-unlock.mockups.md#invalid-token-state",
      "routePolicy": "bdd",
      "tags": [
        "timing:in-ticket"
      ]
    },
    {
      "id": "BR-2.1",
      "kind": "behavior",
      "text": "WHEN POST /api/auth/session receives a valid owner token, the system shall return a successful session response with a server-managed session cookie.",
      "sourceRef": "docs/CRs/MDT-176-browser-auth-session-unlock.md#scope; docs/design/surfaces/auth-session-unlock.spec.md#unlock-flow",
      "routePolicy": "tests",
      "tags": [
        "timing:in-ticket"
      ]
    },
    {
      "id": "BR-2.2",
      "kind": "behavior",
      "text": "WHEN a protected backend API route receives a valid owner session cookie, the system shall authenticate the request as an owner request.",
      "sourceRef": "docs/CRs/MDT-176-browser-auth-session-unlock.md#scope; docs/CRs/MDT-176/assess.md#backend-api-auth-middleware",
      "routePolicy": "tests",
      "tags": [
        "timing:in-ticket"
      ]
    },
    {
      "id": "BR-2.3",
      "kind": "behavior",
      "text": "WHEN the browser session is cleared through the lock or logout flow, the system shall invalidate the session cookie for subsequent protected API requests.",
      "sourceRef": "docs/CRs/MDT-176-browser-auth-session-unlock.md#functional; docs/design/surfaces/auth-session-unlock.spec.md#critical-ux-rules",
      "routePolicy": "tests",
      "tags": [
        "timing:in-ticket"
      ]
    },
    {
      "id": "BR-3.1",
      "kind": "behavior",
      "text": "The system shall provide operator documentation for enabling auth, unlocking browser sessions, cookie and security behavior, logout, and local no-auth mode.",
      "sourceRef": "docs/CRs/MDT-176-browser-auth-session-unlock.md#affected-areas; docs/CRs/MDT-176/assess.md#dependency-and-tooling-pressure",
      "routePolicy": "tests",
      "tags": [
        "timing:in-ticket"
      ]
    },
    {
      "id": "C1",
      "kind": "constraint",
      "text": "The system shall never store or expose the raw admin token in browser storage, URL state, logs, telemetry, or visible error text.",
      "sourceRef": "docs/CRs/MDT-176-browser-auth-session-unlock.md#security; docs/design/surfaces/auth-session-unlock.spec.md#storage-and-security",
      "routePolicy": "tests",
      "tags": [
        "timing:in-ticket"
      ]
    },
    {
      "id": "C2",
      "kind": "constraint",
      "text": "The system shall set the owner session cookie with HttpOnly, SameSite=Strict, and Secure in HTTPS or production deployments.",
      "sourceRef": "docs/CRs/MDT-176-browser-auth-session-unlock.md#desired-outcome; docs/CRs/MDT-176-browser-auth-session-unlock.md#security",
      "routePolicy": "tests",
      "tags": [
        "timing:in-ticket"
      ]
    },
    {
      "id": "C3",
      "kind": "constraint",
      "text": "The system shall validate session exchange tokens using the existing MDT-157 owner token rules rather than a separate credential parser.",
      "sourceRef": "docs/CRs/MDT-176-browser-auth-session-unlock.md#security; docs/CRs/MDT-176/assess.md#backend-api-auth-middleware",
      "routePolicy": "tests",
      "tags": [
        "timing:in-ticket"
      ]
    },
    {
      "id": "C4",
      "kind": "constraint",
      "text": "The system shall include a documented CSRF mitigation decision and matching verification for cookie-authenticated mutation routes.",
      "sourceRef": "docs/CRs/MDT-176-browser-auth-session-unlock.md#security; docs/CRs/MDT-176/assess.md#cookie-authenticated-mutation-safety",
      "routePolicy": "tests",
      "tags": [
        "timing:in-ticket"
      ]
    },
    {
      "id": "C5",
      "kind": "constraint",
      "text": "The system shall keep MDT-176 authentication state behavior independent of MDT-172 authorization and sharing behavior so MDT-176 can ship first.",
      "sourceRef": "docs/CRs/MDT-176-browser-auth-session-unlock.md#out-of-scope; docs/CRs/MDT-176/assess.md#recommendation",
      "routePolicy": "tests",
      "tags": [
        "timing:in-ticket"
      ]
    },
    {
      "id": "C6",
      "kind": "constraint",
      "text": "The system shall preserve MDT-157 header-token authentication, health/status exemptions, and local no-auth compatibility after session-cookie support is added.",
      "sourceRef": "docs/CRs/MDT-176/assess.md#verification-gaps; docs/CRs/MDT-157-api-auth.md#acceptance-criteria",
      "routePolicy": "tests",
      "tags": [
        "timing:in-ticket"
      ]
    },
    {
      "id": "C7",
      "kind": "constraint",
      "text": "The system shall not introduce multi-user accounts, RBAC, OAuth, password login, token rotation, or refresh-token behavior for this ticket.",
      "sourceRef": "docs/CRs/MDT-176-browser-auth-session-unlock.md#out-of-scope",
      "routePolicy": "tests",
      "tags": [
        "timing:in-ticket"
      ]
    },
    {
      "id": "C8",
      "kind": "constraint",
      "text": "The system shall document auth setup, browser unlock, session cookie behavior, logout, security expectations, and local no-auth behavior in operator-facing documentation.",
      "sourceRef": "docs/CRs/MDT-176-browser-auth-session-unlock.md#affected-areas; docs/CRs/MDT-176/assess.md#dependency-and-tooling-pressure",
      "routePolicy": "tests",
      "tags": [
        "timing:in-ticket"
      ]
    },
    {
      "id": "Edge-1",
      "kind": "edge_case",
      "text": "IF the backend is unavailable or returns a server error, THEN the system shall show the backend-down state instead of the locked-board state.",
      "sourceRef": "docs/design/surfaces/auth-session-unlock.spec.md#state-model; docs/CRs/MDT-176/assess.md#verification-gaps",
      "routePolicy": "tests",
      "tags": [
        "timing:in-ticket"
      ]
    },
    {
      "id": "Edge-2",
      "kind": "edge_case",
      "text": "IF an SSE or reconnecting request observes a cleared or rejected session, THEN the system shall converge back to locked state without showing stale owner controls.",
      "sourceRef": "docs/CRs/MDT-176/assess.md#verification-gaps; docs/design/surfaces/auth-session-unlock.spec.md#state-model",
      "routePolicy": "tests",
      "tags": [
        "timing:in-ticket"
      ]
    },
    {
      "id": "Edge-3",
      "kind": "edge_case",
      "text": "IF anonymous GET /api/projects returns 401 before MDT-172 or 200 after MDT-172, THEN the system shall distinguish locked, public-read-only, and public-empty states by response semantics.",
      "sourceRef": "docs/CRs/MDT-176-browser-auth-session-unlock.md#mdt-172-compatibility; docs/design/surfaces/auth-session-unlock.spec.md#mdt-172-compatibility",
      "routePolicy": "tests",
      "tags": [
        "timing:in-ticket"
      ]
    },
    {
      "id": "BR-2.4",
      "kind": "behavior",
      "text": "IF a session exchange or session-authenticated request has missing or invalid credentials, THEN the system shall reject the request with a generic authentication failure.",
      "sourceRef": "docs/CRs/MDT-176-browser-auth-session-unlock.md#functional; docs/CRs/MDT-157-api-auth.md#acceptance-criteria",
      "routePolicy": "tests",
      "tags": [
        "timing:in-ticket"
      ]
    },
    {
      "id": "C9",
      "kind": "constraint",
      "text": "The system shall verify locked, unlock, invalid unlock, logout, and hidden admin controls in an isolated auth-enabled Playwright E2E setup without changing the default no-auth E2E suite.",
      "sourceRef": "docs/CRs/MDT-176-browser-auth-session-unlock.md#verification; docs/CRs/MDT-176/assess.md#verification-harness; tests/AGENTS.md",
      "routePolicy": "tests",
      "tags": [
        "timing:in-ticket"
      ]
    }
  ],
  "scenarios": [
    {
      "id": "locked_backend_shows_unlock_panel",
      "title": "Locked backend shows unlock panel instead of empty project UI",
      "covers": [
        "BR-1.1",
        "BR-1.2",
        "BR-1.5"
      ],
      "given": "the backend requires owner authentication and I have no owner session",
      "when": "I open the board",
      "then": "I see a Board is locked message with an access-token input and unlock action, and project-management actions are not available",
      "sourceRef": "docs/CRs/MDT-176/requirements.trace.md#br-11; docs/design/surfaces/auth-session-unlock.spec.md#locked-panel"
    },
    {
      "id": "successful_unlock_starts_owner_session",
      "title": "Valid token unlocks owner session and loads projects",
      "covers": [
        "BR-1.3",
        "BR-1.5"
      ],
      "given": "the board is locked and I have a valid owner access token",
      "when": "I submit the token from the unlock panel",
      "then": "the board loads manageable projects, shows owner-session status, and owner-only actions become available",
      "sourceRef": "docs/CRs/MDT-176/requirements.trace.md#br-13; docs/design/surfaces/auth-session-unlock.spec.md#unlock-flow"
    },
    {
      "id": "invalid_unlock_stays_locked",
      "title": "Invalid token keeps user in locked correction flow",
      "covers": [
        "BR-1.4",
        "BR-1.10"
      ],
      "given": "the board is locked and I enter an invalid access token",
      "when": "I submit the unlock form",
      "then": "I remain on the locked panel with a generic token rejection message and can correct the token from the same context",
      "sourceRef": "docs/CRs/MDT-176/requirements.trace.md#br-14; docs/design/surfaces/auth-session-unlock.spec.md#accessibility"
    },
    {
      "id": "local_no_auth_loads_normally",
      "title": "Local no-auth mode bypasses unlock prompt",
      "covers": [
        "BR-1.7"
      ],
      "given": "backend authentication is disabled for local development or test mode",
      "when": "I open the application",
      "then": "the normal project experience loads without showing an unlock prompt",
      "sourceRef": "docs/CRs/MDT-176/requirements.trace.md#br-17; docs/CRs/MDT-176-browser-auth-session-unlock.md#scope"
    },
    {
      "id": "public_projects_remain_read_only",
      "title": "Anonymous public projects remain read-only with unlock affordance",
      "covers": [
        "BR-1.8",
        "BR-1.5"
      ],
      "given": "MDT-172 public read-only project listing is available and I have no owner session",
      "when": "I open the application and public projects are returned",
      "then": "I can view public projects, see an unlock affordance, and project-management actions remain unavailable",
      "sourceRef": "docs/CRs/MDT-176/requirements.trace.md#br-18; docs/design/surfaces/auth-session-unlock.spec.md#mdt-172-compatibility"
    },
    {
      "id": "public_empty_shows_unlock_only",
      "title": "Anonymous public-empty state does not expose project creation",
      "covers": [
        "BR-1.9",
        "BR-1.5"
      ],
      "given": "MDT-172 public read-only listing is available and no public projects are returned",
      "when": "I open the application without an owner session",
      "then": "I see a no-public-projects message with an unlock affordance and no project-creation action",
      "sourceRef": "docs/CRs/MDT-176/requirements.trace.md#br-19; docs/design/surfaces/auth-session-unlock.mockups.md#anonymous-public-empty-state-after-mdt-172"
    },
    {
      "id": "lock_action_returns_to_locked_state",
      "title": "Lock action ends owner session without changing project data",
      "covers": [
        "BR-1.6"
      ],
      "given": "I have unlocked an owner session and projects are visible",
      "when": "I use the lock action and then reload or request protected project data",
      "then": "the board remains locked and no project data is changed",
      "sourceRef": "docs/CRs/MDT-176/requirements.trace.md#br-16; docs/design/surfaces/auth-session-unlock.mockups.md#owner-session-unlocked"
    }
  ],
