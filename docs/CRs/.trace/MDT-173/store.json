{
  "version": 1,
  "ticket": {
    "key": "MDT-173"
  },
  "requirements": [
    {
      "id": "BR-10.1",
      "kind": "behavior",
      "text": "Documents View keeps prose text at a readable measure while rendered wide artifacts such as Wireloom, Mermaid, tables, and code blocks can use the available document pane and scroll horizontally only when their intrinsic width exceeds that pane.",
      "sourceRef": "CR:MDT-173",
      "routePolicy": "bdd"
    },
    {
      "id": "BR-10.2",
      "kind": "behavior",
      "text": "Documents View lets users resize and collapse the document navigation sidebar, preserves the sidebar width and collapsed state per project, and keeps navigation controls readable by placing search and sorting on the second header row, with search flexing left of sort and direction controls.",
      "sourceRef": "CR:MDT-173",
      "routePolicy": "bdd"
    },
    {
      "id": "C10",
      "kind": "constraint",
      "text": "Readable prose width must remain constrained; widening artifact rendering must not make normal document paragraphs span the full desktop pane.",
      "sourceRef": "CR:MDT-173",
      "routePolicy": "tests"
    }
  ],
  "scenarios": [
    {
      "id": "document_artifacts_use_available_width",
      "title": "Wide document artifacts use available pane width",
      "covers": [
        "BR-10.1"
      ],
      "given": "a document contains readable prose and a wide rendered artifact",
      "when": "the document is opened in a wide Documents View pane",
      "then": "normal prose remains constrained to a readable measure and the artifact container uses the available pane width before horizontal scrolling is needed",
      "sourceRef": "CR:MDT-173"
    },
    {
      "id": "document_navigation_resizes_and_collapses",
      "title": "Document navigation can resize, collapse, and keep search/sort controls readable",
      "covers": [
        "BR-10.2"
      ],
      "given": "a user is viewing Documents View with the navigation sidebar visible",
      "when": "the user uses navigation controls or resizes or collapses the document navigation panel",
      "then": "search flexes left of the sort and direction controls, the preview pane adjusts immediately, and the navigation panel state is preserved for the project",
      "sourceRef": "CR:MDT-173"
    }
  ],
  "obligations": [
    {
      "id": "OBL-resizable-document-navigation",
