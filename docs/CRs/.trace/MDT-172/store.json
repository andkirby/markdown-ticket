{
  "version": 1,
  "ticket": {
    "key": "MDT-172"
  },
  "requirements": [
    {
      "id": "BR-1.1",
      "kind": "behavior",
      "text": "The system shall keep every active project private until sharing is explicitly enabled.",
      "sourceRef": "CR Functional AC 1",
      "routePolicy": "bdd",
      "tags": [
        "timing:now"
      ]
    },
    {
      "id": "BR-1.2",
      "kind": "behavior",
      "text": "WHEN an anonymous visitor requests the project list, the system shall return only active projects configured as public-readonly.",
      "sourceRef": "CR Functional AC 3-4",
      "routePolicy": "bdd",
      "tags": [
        "timing:now"
      ]
    },
    {
      "id": "BR-1.3",
      "kind": "behavior",
      "text": "WHEN an anonymous visitor opens /share/{shareId} with a valid unlisted-readonly share ID, the system shall open that project without adding it to the anonymous project list.",
      "sourceRef": "CR Functional AC 4-5",
      "routePolicy": "bdd",
      "tags": [
        "timing:now"
      ]
    },
    {
      "id": "BR-1.4",
      "kind": "behavior",
      "text": "WHEN an anonymous or read-token visitor reads tickets or documents for a visible shared project, the system shall return the normal read data for that project.",
      "sourceRef": "CR Functional AC 6",
      "routePolicy": "bdd",
      "tags": [
        "timing:now"
      ]
    },
    {
      "id": "BR-1.5",
      "kind": "behavior",
      "text": "WHEN a read-only visitor attempts any project, ticket, document, filesystem, or favorite mutation, the system shall return 403 and shall not change persisted state.",
      "sourceRef": "CR Functional AC 7, 13",
      "routePolicy": "bdd",
      "tags": [
        "timing:now"
      ]
    },
    {
      "id": "BR-1.6",
      "kind": "behavior",
      "text": "WHEN an owner/admin changes project sharing in Settings, the system shall persist Private, Unlisted read-only, or Public read-only for that project.",
      "sourceRef": "CR Functional AC 2",
      "routePolicy": "bdd",
      "tags": [
        "timing:now"
      ]
    },
    {
      "id": "BR-1.7",
      "kind": "behavior",
      "text": "WHEN a visitor enters a valid scoped read token, the system shall expand the visible project list to only token-scoped projects and keep those projects read-only.",
      "sourceRef": "CR Functional AC 9-10",
      "routePolicy": "bdd",
      "tags": [
        "timing:now"
      ]
    },
    {
      "id": "BR-1.8",
      "kind": "behavior",
      "text": "WHEN a visitor enters an invalid scoped read token or exchange code, the system shall show a generic denial without revealing project existence.",
      "sourceRef": "CR Functional AC 11",
      "routePolicy": "bdd",
      "tags": [
        "timing:now"
      ]
    },
    {
      "id": "BR-1.9",
      "kind": "behavior",
      "text": "WHEN a share URL contains a one-time code, the browser shall exchange it through POST storage and then remove the code from the address bar.",
      "sourceRef": "CR Functional AC 12",
      "routePolicy": "bdd",
      "tags": [
        "timing:now"
      ]
    },
    {
      "id": "BR-1.10",
      "kind": "behavior",
      "text": "WHILE the user has read-only access, the UI shall hide or disable project creation, project editing, ticket creation, drag/drop, status toggles, deletes, document favorite writes, and document configuration controls.",
      "sourceRef": "CR Functional AC 13",
      "routePolicy": "bdd",
      "tags": [
        "timing:now"
      ]
    },
    {
      "id": "C1",
      "kind": "constraint",
      "text": "The system shall use non-enumerable random identifiers for share IDs and read tokens.",
      "sourceRef": "CR Security Constraints",
      "routePolicy": "tests",
      "tags": [
        "timing:now"
      ]
    },
    {
      "id": "C2",
      "kind": "constraint",
      "text": "The system shall store only token hashes server-side and shall not log raw tokens, cookies, authorization headers, or one-time exchange codes.",
      "sourceRef": "CR Security Constraints",
      "routePolicy": "tests",
      "tags": [
        "timing:now"
      ]
    },
    {
      "id": "C3",
      "kind": "constraint",
      "text": "The system shall keep owner/admin credentials out of URLs and browser-readable storage.",
      "sourceRef": "CR Security Constraints",
      "routePolicy": "tests",
      "tags": [
        "timing:now"
      ]
    },
    {
      "id": "C4",
      "kind": "constraint",
      "text": "The system shall keep backend authorization as the source of truth for every mutation.",
      "sourceRef": "CR Success Conditions",
      "routePolicy": "tests",
      "tags": [
        "timing:now"
      ]
    },
    {
      "id": "C5",
      "kind": "constraint",
      "text": "SSE subscriptions shall filter events to the caller's visible project scope and shall not carry read or admin tokens in query strings.",
      "sourceRef": "CR Security Constraints",
      "routePolicy": "tests",
      "tags": [
        "timing:now"
      ]
    },
    {
      "id": "Edge-1",
      "kind": "edge_case",
      "text": "A token scoped to zero projects shall authenticate successfully and reveal no additional projects.",
      "sourceRef": "CR Edge Cases",
      "routePolicy": "tests",
      "tags": [
        "timing:now"
      ]
    },
    {
      "id": "Edge-2",
      "kind": "edge_case",
      "text": "A project switched from public-readonly to unlisted-readonly shall disappear from anonymous project lists but remain reachable by its share ID.",
      "sourceRef": "CR Edge Cases",
      "routePolicy": "tests",
      "tags": [
        "timing:now"
      ]
    },
    {
      "id": "Edge-3",
      "kind": "edge_case",
      "text": "A disabled shared project shall disappear from anonymous and token-scoped lists and shall stop resolving through its share ID.",
      "sourceRef": "CR Edge Cases",
      "routePolicy": "tests",
      "tags": [
        "timing:now"
      ]
    },
    {
      "id": "Edge-4",
      "kind": "edge_case",
      "text": "Expired, revoked, malformed, or replayed one-time codes shall fail with a generic denial.",
      "sourceRef": "CR Edge Cases",
      "routePolicy": "tests",
      "tags": [
        "timing:now"
      ]
    },
    {
      "id": "C6",
      "kind": "constraint",
      "text": "The system shall not widen CORS allowlists or Origin handling for sharing endpoints.",
      "sourceRef": "CR Security Constraints",
      "routePolicy": "tests",
      "tags": [
        "timing:now"
      ]
    },
    {
      "id": "C7",
      "kind": "constraint",
      "text": "The system shall enforce concrete CSRF and Origin protection for cookie-backed owner/admin mutations.",
      "sourceRef": "CR Security Constraints",
      "routePolicy": "tests",
      "tags": [
        "timing:now"
      ]
    },
    {
      "id": "C8",
      "kind": "constraint",
      "text": "Token entry and exchange endpoints shall be rate limited or explicitly bounded by the existing deployment rate-limit policy and shall return generic errors.",
      "sourceRef": "CR Security Constraints",
      "routePolicy": "tests",
      "tags": [
        "timing:now"
      ]
    }
  ],
  "scenarios": [
    {
      "id": "private_by_default",
      "title": "Private projects are hidden by default",
      "covers": [
        "BR-1.1"
      ],
      "given": "Given a fresh deployment with active projects and no sharing configuration",
      "when": "When an anonymous visitor opens the app",
      "then": "Then the project list is empty and no private project metadata is displayed",
      "sourceRef": "BDD private visibility"
    },
    {
      "id": "anonymous_public_listing",
      "title": "Anonymous list includes only public projects",
      "covers": [
        "BR-1.2"
      ],
      "given": "Given one project is public-readonly, one is unlisted-readonly, and one is private",
      "when": "When an anonymous visitor requests the project list",
      "then": "Then only the public-readonly project is returned",
      "sourceRef": "BDD public list"
    },
    {
      "id": "unlisted_share_link_opens_project",
      "title": "Unlisted share link opens a project",
      "covers": [
        "BR-1.3",
        "BR-1.4"
      ],
      "given": "Given a project is unlisted-readonly with a valid share ID",
      "when": "When an anonymous visitor opens /share/{shareId}",
      "then": "Then the visitor sees the shared board/list/documents data for that project",
      "sourceRef": "BDD share route"
    },
    {
      "id": "readonly_mutations_are_denied",
      "title": "Read-only visitors cannot mutate shared projects",
      "covers": [
        "BR-1.5"
      ],
      "given": "Given an anonymous visitor can read a shared project",
      "when": "When the visitor sends POST, PATCH, PUT, or DELETE requests for that project",
      "then": "Then each request returns 403 and persisted project data is unchanged",
      "sourceRef": "BDD mutation denial"
    },
    {
      "id": "owner_updates_project_sharing",
      "title": "Owner changes project sharing settings",
      "covers": [
        "BR-1.6"
      ],
      "given": "Given an owner/admin session is unlocked",
      "when": "When the owner sets a project to Private, Unlisted read-only, or Public read-only in Settings",
      "then": "Then the saved sharing mode changes the project visibility on the next read",
      "sourceRef": "BDD owner settings"
    },
    {
      "id": "scoped_read_token_expands_projects",
      "title": "Scoped read token reveals only scoped projects",
      "covers": [
        "BR-1.7"
      ],
      "given": "Given a scoped read token grants access to two projects",
      "when": "When a visitor submits the token through the authorization flow",
      "then": "Then those projects are visible and remain read-only",
      "sourceRef": "BDD token auth"
    },
    {
      "id": "invalid_token_generic_denial",
      "title": "Invalid read tokens fail generically",
      "covers": [
        "BR-1.8"
      ],
      "given": "Given a visitor submits an invalid scoped read token",
      "when": "When the token is rejected",
      "then": "Then the UI shows a generic denial and no project names or counts are revealed",
      "sourceRef": "BDD token denial"
    },
    {
      "id": "share_code_exchange_cleans_url",
      "title": "One-time share code is exchanged and removed from URL",
      "covers": [
        "BR-1.9"
      ],
      "given": "Given a share link contains a one-time code",
      "when": "When the browser opens the link",
      "then": "Then the code is exchanged through POST and the current address no longer contains the code",
      "sourceRef": "BDD one-time exchange"
    },
    {
      "id": "readonly_ui_removes_editing",
      "title": "Read-only UI removes mutation controls",
      "covers": [
        "BR-1.10"
      ],
      "given": "Given a read-only visitor is viewing a shared project",
      "when": "When the board, list, project selector, settings, and documents views render",
      "then": "Then project add/edit, ticket create, drag/drop, status toggles, delete, document favorite, and document configuration controls are unavailable",
      "sourceRef": "BDD read-only UI"
    }
  ],
