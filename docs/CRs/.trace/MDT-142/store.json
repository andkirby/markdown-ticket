{
  "version": 1,
  "ticket": {
    "key": "MDT-142"
  },
  "requirements": [
    {
      "id": "BR-1.3",
      "kind": "behavior",
      "text": "WHEN a file exists in both main project and an active worktree, the system shall emit exactly one SSE event for that file change",
      "sourceRef": "CR Section 3 - Solution Analysis, Worktree Exclusion",
      "routePolicy": "bdd",
      "tags": [
        "timing:now"
      ]
    },
    {
      "id": "BR-1.4",
      "kind": "behavior",
      "text": "WHEN the frontend receives an SSE event with subdocument metadata, the system shall emit ticket:subdocument:changed to enable targeted UI updates without full ticket refresh",
      "sourceRef": "CR Section 4.6 - Frontend Event Mapping",
      "routePolicy": "bdd",
      "tags": [
        "timing:now"
      ]
    },
    {
      "id": "C1",
      "kind": "constraint",
      "text": "The main project file watcher shall use recursive pattern docs/CRs/**/*.md to capture subdocument changes",
      "sourceRef": "CR Section 4.2 - Watcher Pattern Changes",
      "routePolicy": "tests",
      "tags": [
        "timing:now"
      ]
    },
    {
      "id": "C2",
      "kind": "constraint",
      "text": "The main project watcher shall exclude active worktree ticket paths (docs/CRs/MDT-XXX/*.md and docs/CRs/MDT-XXX-*.md) to prevent duplicate events",
      "sourceRef": "CR Section 4.3 - Worktree Exclusion Rules",
      "routePolicy": "tests",
      "tags": [
        "timing:now"
      ]
    },
    {
      "id": "C3",
      "kind": "constraint",
      "text": "The system shall monitor .git/worktrees/{worktreeName}/HEAD files for changes to trigger watcher reconfiguration",
      "sourceRef": "CR Section 4.5 - Worktree Monitoring",
      "routePolicy": "tests",
      "tags": [
        "timing:now"
      ]
    },
    {
      "id": "C4",
      "kind": "constraint",
      "text": "Main ticket file changes shall emit ticket:updated event as before with no breaking changes to existing SSE event consumers",
      "sourceRef": "CR Section 5 AC5 - Backward Compatibility",
      "routePolicy": "tests",
      "tags": [
        "timing:now"
      ]
    },
    {
      "id": "Edge-2",
      "kind": "edge_case",
      "text": "WHEN a subdocument is created or deleted (not just modified), the system shall emit SSE events with the appropriate eventType (add/unlink) and subdocument metadata",
      "sourceRef": "CR Section 4.1 - SSE Event Structure",
      "routePolicy": "tests",
      "tags": [
        "timing:now"
      ]
    },
    {
      "id": "BR-1.2",
      "kind": "behavior",
      "text": "WHEN a worktree is added or removed, the system shall automatically detect the change and reconfigure file watchers",
      "sourceRef": "CR Section 4.5 - Worktree Monitoring",
      "routePolicy": "bdd",
      "tags": [
        "timing:now"
      ]
    },
    {
      "id": "Edge-1",
      "kind": "edge_case",
      "text": "WHEN a worktree is removed while watchers are active, the system shall clean up the worktree watcher and remove exclusions from main watcher",
      "sourceRef": "CR Section 4.5 - Worktree Monitoring",
      "routePolicy": "tests",
      "tags": [
        "timing:now"
      ]
    },
    {
      "id": "BR-1.1",
      "kind": "behavior",
      "text": "WHEN a subdocument file changes (in main project or worktree), the system shall emit an SSE event containing the subdocument code, file path, and source indicator",
      "sourceRef": "CR Section 4.1 - SSE Event Structure",
      "routePolicy": "bdd",
      "tags": [
        "timing:now"
      ]
    }
  ],
  "scenarios": [
    {
      "id": "worktree_add_auto_detects",
      "title": "Worktree addition auto-detects and reconfigures watchers",
      "covers": [
        "BR-1.2"
      ],
      "given": "I have a main project with file watching active",
      "when": "a new worktree is created for a ticket",
      "then": "changes made in the worktree are reflected in the main project UI in real-time",
      "sourceRef": "CR:MDT-142"
    },
    {
      "id": "no_duplicate_events_worktree",
      "title": "No duplicate events when file exists in both main and worktree",
      "covers": [
        "BR-1.3"
      ],
      "given": "a ticket file exists in both main project and an active worktree",
      "when": "the file is modified in either location",
      "then": "the UI receives exactly one update event (not two)",
      "sourceRef": "CR:MDT-142"
    },
    {
      "id": "subdocument_sse_event_main_project",
      "title": "Subdocument change in main project triggers SSE event",
      "covers": [
        "BR-1.1",
        "BR-1.4"
      ],
      "given": "I am viewing a ticket with subdocuments in the main project",
      "when": "a subdocument file is modified in the main project ticket folder",
      "then": "the SSE event contains the subdocument code, file path, and source='main'",
      "sourceRef": "CR:MDT-142"
    },
    {
      "id": "subdocument_sse_event_worktree",
      "title": "Subdocument change in worktree triggers SSE event",
      "covers": [
        "BR-1.1",
        "BR-1.4",
        "BR-1.2"
      ],
      "given": "I have an active worktree for a ticket with subdocuments",
      "when": "a subdocument file is modified in the worktree ticket folder",
      "then": "the SSE event contains the subdocument code, file path, and source='worktree'",
      "sourceRef": "CR:MDT-142"
    }
  ],
