{
  "version": 1,
  "ticket": {
    "key": "MDT-178"
  },
  "requirements": [
    {
      "id": "BR-1.1",
      "kind": "behavior",
      "text": "WHEN the backend starts, the system shall parse runtime environment variables once into a typed RuntimeConfig object before routes and middleware are registered.",
      "sourceRef": "CR Acceptance Criteria: typed runtime config module",
      "routePolicy": "bdd",
      "tags": [
        "timing:now"
      ]
    },
    {
      "id": "C1",
      "kind": "constraint",
      "text": "Backend feature modules shall not read process.env directly; direct env reads are limited to server/config, startup wiring, development utilities, and test setup code.",
      "sourceRef": "CR Acceptance Criteria: process.env boundary",
      "routePolicy": "tests",
      "tags": [
        "timing:now"
      ]
    },
    {
      "id": "C3",
      "kind": "constraint",
      "text": "Runtime deployment hostnames, public link origins, CORS origins, and read-session secrets shall remain outside project-local .mdt-config.toml.",
      "sourceRef": "docs/architecture/runtime-configuration-architecture.md",
      "routePolicy": "tests",
      "tags": [
        "timing:now"
      ]
    },
    {
      "id": "C4",
      "kind": "constraint",
      "text": "Route and unit tests shall configure runtime assumptions through explicit env maps or app-local RuntimeConfig creation before routes run; request-time RuntimeConfig fallback creation is not allowed.",
      "sourceRef": "docs/CRs/MDT-178/requirements.md",
      "routePolicy": "tests"
    },
    {
      "id": "BR-1.2",
      "kind": "behavior",
      "text": "WHEN PUBLIC_ORIGIN is configured, the system shall expose that full origin as the generated share and invite link base and as a backend allowed browser origin.",
      "sourceRef": "docs/CRs/MDT-178/requirements.md",
      "routePolicy": "bdd"
    },
    {
      "id": "BR-1.3",
      "kind": "behavior",
      "text": "WHEN PUBLIC_ORIGIN is absent, the system shall not derive generated public link origins from other app origin environment variables or hostnames.",
      "sourceRef": "docs/CRs/MDT-178/requirements.md",
      "routePolicy": "bdd"
    },
    {
      "id": "BR-1.4",
      "kind": "behavior",
      "text": "WHEN PUBLIC_ORIGIN is absent and the current browser origin is allowed, the system shall use the current origin derived from Origin or Referer for generated sharing links.",
      "sourceRef": "docs/CRs/MDT-178/requirements.md",
      "routePolicy": "bdd"
    },
    {
      "id": "BR-1.5",
      "kind": "behavior",
      "text": "WHEN no configured public origin is available and the current browser origin is rejected or absent, the system shall report that no safe generated-link origin can be selected.",
      "sourceRef": "docs/CRs/MDT-178/requirements.md",
      "routePolicy": "bdd"
    },
    {
      "id": "C2",
      "kind": "constraint",
      "text": "PUBLIC_ORIGIN shall be the only configured deployment origin variable for app browser-origin and generated-link behavior.",
      "sourceRef": "docs/CRs/MDT-178/requirements.md",
      "routePolicy": "tests"
    }
  ],
  "scenarios": [
    {
      "id": "runtime_config_startup_boundary",
      "title": "Runtime config is parsed once at startup",
      "covers": [
        "BR-1.1"
      ],
      "given": "the backend process has runtime environment variables",
      "when": "the server app is created",
      "then": "routes and middleware use the app runtime config instead of reading env during request handling",
      "sourceRef": "requirements.md#runtime-config-owner"
    },
    {
      "id": "public_origin_is_used",
      "title": "Configured public origin is used",
      "covers": [
        "BR-1.2"
      ],
      "given": "PUBLIC_ORIGIN contains a full origin",
      "when": "an owner opens sharing settings and generates an invite",
      "then": "the generated invite link uses PUBLIC_ORIGIN",
      "sourceRef": "docs/CRs/MDT-178/bdd.md"
    },
    {
      "id": "current_origin_fallback_reported",
      "title": "Current origin fallback remains safe and visible",
      "covers": [
        "BR-1.3",
        "BR-1.4"
      ],
      "given": "PUBLIC_ORIGIN is absent",
      "when": "an owner lists read-access link options or creates an invite from an allowed current origin",
      "then": "the generated public link origin is the allowed current origin",
      "sourceRef": "docs/CRs/MDT-178/bdd.md"
    },
    {
      "id": "no_safe_origin_reported",
      "title": "Missing safe origin blocks invite links",
      "covers": [
        "BR-1.5"
      ],
      "given": "no configured public origin is available",
      "when": "an owner opens sharing settings from a rejected current origin",
      "then": "the UI reports that no safe generated-link origin exists",
      "sourceRef": "docs/CRs/MDT-178/bdd.md"
    }
  ],
